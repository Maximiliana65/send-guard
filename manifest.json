{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "0.5.1",
  "default_locale": "ja",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "core/chatgpt-page-guard.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "core/gemini-page-guard.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "core/settings-store.js",
        "core/dom-utils.js",
        "core/lock-guard.js",
        "fun/comments.ja.js",
        "fun/comments.en.js",
        "fun/fun-engine.js",
        "adapters/claude.js",
        "core/content-main.js"
      ],
      "css": [
        "core/lock-ui.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "core/settings-store.js",
        "core/dom-utils.js",
        "core/lock-guard.js",
        "fun/comments.ja.js",
        "fun/comments.en.js",
        "fun/fun-engine.js",
        "adapters/chatgpt.js",
        "core/content-main.js"
      ],
      "css": [
        "core/lock-ui.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "core/settings-store.js",
        "core/dom-utils.js",
        "core/lock-guard.js",
        "fun/comments.ja.js",
        "fun/comments.en.js",
        "fun/fun-engine.js",
        "adapters/gemini.js",
        "core/content-main.js"
      ],
      "css": [
        "core/lock-ui.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
